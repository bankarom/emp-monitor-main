{
  "name": "emp-monitor-agent",
  "version": "1.0.0",
  "description": "EmpMonitor Desktop Agent - Employee Monitoring Software",
  "main": "main.js",
  "author": "EmpMonitor",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build-portable": "electron-builder --win portable"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "electron-store": "^8.2.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.empmonitor.agent",
    "productName": "EmpMonitor Agent",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "extraResources": [
      "resources/**/*"
    ],
    "files": [
      "src/**/*",
      "main.js",
      "package.json"
    ]
  }
}
